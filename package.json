{
	"name": "tp2-clean",
	"private": false,
	"type": "module",
	"engines": {
		"bun": "^1.3.9"
	},
	"scripts": {
		"init": "bun install && npx convex dev --once --configure=new",
		"dev:backend": "bun run convex dev",
		"dev:frontend": "vite dev --port 3000",
		"dev": "bun run --parallel \"dev:backend\" \"dev:frontend\"",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"deploy": "bun run build && wrangler deploy",
		"format": "bun run migrate:biome && biome format",
		"lint": "bun run migrate:biome && biome lint && eslint",
		"check": "bun run migrate:biome && biome check && eslint .",
		"fix": "bun run migrate:biome && biome check --fix && eslint --fix .",
		"build-ci": "bun run fix && tsc --noEmit && bun run build",
		"knip": "knip",
		"migrate": "bun run migrate:biome && bun run migrate:tailwind",
		"migrate:biome": "bun run biome migrate --write",
		"migrate:tailwind": "bunx @tailwindcss/upgrade"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@cloudflare/vite-plugin": "^1.26.1",
		"@convex-dev/react-query": "0.1.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@t3-oss/env-core": "^0.13.10",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-devtools": "^0.9.0",
		"@tanstack/react-form": "^1.28.4",
		"@tanstack/react-form-devtools": "^0.2.17",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router": "^1.166.2",
		"@tanstack/react-router-devtools": "^1.166.2",
		"@tanstack/react-router-ssr-query": "^1.166.2",
		"@tanstack/react-start": "^1.166.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex": "^1.32.0",
		"lucide-react": "^0.577.0",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"shadcn": "^4.0.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"vite-tsconfig-paths": "^6.1.1",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@convex-dev/eslint-plugin": "^1.1.1",
		"@tanstack/devtools-vite": "^0.5.0",
		"@tanstack/eslint-plugin-query": "^5.91.4",
		"@tanstack/eslint-plugin-router": "^1.161.4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "9",
		"eslint-plugin-better-tailwindcss": "^4.3.2",
		"eslint-plugin-jest-dom": "^5.5.0",
		"eslint-plugin-testing-library": "^7.16.0",
		"jsdom": "^29.0.0",
		"knip": "^6.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.0",
		"wrangler": "^4.71.0"
	}
}
