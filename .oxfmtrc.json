{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": false,
	"ignorePatterns": [
		"**/convex/_generated/**",
		"**/src/routeTree.gen.ts",
		"**/dist/**",
		"**/*.generated.ts",
		"**/*.generated.json",
		"**/src/1_components/ui/**", // would just complicate diffs
		"**/node_modules/**",
		"reset.d.ts"
	],
	"sortImports": {
		"internalPattern": ["#*", "#*/**"],
		"customGroups": [
			{ "groupName": "common", "elementNamePattern": ["#common/**"] },
			{ "groupName": "convex", "elementNamePattern": ["#convex/**"] },
			{ "groupName": "src_5", "elementNamePattern": ["#src/5_*/**"] },
			{ "groupName": "src_4", "elementNamePattern": ["#src/4_*/**"] },
			{ "groupName": "src_3", "elementNamePattern": ["#src/3_*/**"] },
			{ "groupName": "src_2", "elementNamePattern": ["#src/2_*/**"] },
			{ "groupName": "src_1", "elementNamePattern": ["#src/1_*/**"] },
			{ "groupName": "src_0", "elementNamePattern": ["#src/0_*/**"] }
		],
		"groups": [
			"builtin",
			"external",
			"common",
			"convex",
			"src_5",
			"src_4",
			"src_3",
			"src_2",
			"src_1",
			"src_0",
			"unknown"
		]
	}
}
